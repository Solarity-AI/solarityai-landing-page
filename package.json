{
  "name": "solarityai-landing-page",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i assets/css/tailwind-src.css -o assets/css/tailwind.css --minify",
    "build:minify:css": "cleancss -O2 -o assets/css/main.min.css assets/css/main.css",
    "build:minify:js": "terser assets/js/language.js -o assets/js/language.min.js -c -m && terser assets/js/translations.js -o assets/js/translations.min.js -c -m",
    "build:images": "node scripts/build-images-webp.js",
    "serve": "node server.js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "terser": "^5.36.0"
  }
}
